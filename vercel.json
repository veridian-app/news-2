{
  "crons": [
    {
      "path": "/api/cron-handler?job=generate-covers",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-handler?job=curate-cafe",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron-handler?job=generate-polls",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron-handler?job=analyze-sources&source=boe",
      "schedule": "0 9 * * 1-5"
    },
    {
      "path": "/api/cron-handler?job=analyze-sources&source=bdns",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron-handler?job=analyze-sources&source=placsp",
      "schedule": "0 10 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|@vite|@react-refresh|.*\\.[a-z0-9]+$).*)",
      "destination": "/index.html"
    }
  ]
}