    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nfunction clean(s = '', max = 900) {\n  return String(s)\n    .replace(/\\s+/g, ' ')\n    .replace(/[\\u0000-\\u001F]/g, '')\n    .slice(0, max)\n    .trim();\n}\n\nreturn items.map(item => {\n  const j = item.json;\n\n  // Campos básicos\n  const title = clean(j.title || j.heading || '');\n  const link  = j.link || j.guid || '';\n  const pub   = j.isoDate || j.pubDate || j.published || '';\n\n  // --- SOURCE & DOMAIN ------------------------------\n  // Intentamos sacar algo de los campos del feed\n  let source = j.feed || j.source || j.meta?.link || '';\n  let domain = '';\n\n  // Si tenemos link, sacamos el dominio a mano (sin usar URL())\n  if (link) {\n    const m = String(link).match(/^[a-zA-Z]+:\\/\\/([^\\/?#]+)/);\n    if (m && m[1]) {\n      domain = m[1].replace(/^www\\./, ''); // ej: www.elmundo.es -> elmundo.es\n      if (!source) {\n        source = domain; // usamos el dominio como \"source\" si no había otro\n      }\n    }\n  }\n\n  const desc = clean(\n    j.content ||\n    j['content:encoded'] ||\n    j.description ||\n    ''\n  );\n\n  // Base para el hash (título + link + fecha)\n  const base = `${title}|${link}|${pub}`;\n  const hash = crypto.createHash('sha1').update(base).digest('hex');\n\n  const content_for_llm = `${title} — ${desc}`.slice(0, 900);\n\n  return {\n    json: {\n      timestamp: new Date().toISOString(),\n      source,          // ahora debería tener valor (elmundo.es, elpais.com, etc.)\n      domain,          // dominio limpio, útil para tu tabla de confianza\n      title,\n      link,\n      publishedAt: pub,\n      description: desc,\n      content_for_llm,\n      hash,\n    },\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        208
      ],
      "id": "98e1f400-76c7-433c-b88a-710d7e99a209",
      "name": "Hash_Normalizar"
    },
    {
      "parameters": {
        "jsCode": "// === RESET MANUAL (solo para forzar primera vez, luego bórralo) ===\nconst sd = $getWorkflowStaticData('global');\nsd.initialized = false;  // ⚠️ Solo para resetear UNA VEZ\n\n// === 1) Items ORIGINALES (del nodo que genera el hash) ===\nconst originals = $items('Hash_Normalizar', 0, 0);\n\n// === 2) Respuesta del HTTP (lo que se insertó en Supabase) ===\nconst httpItems = $items('Supabase_Upsert', 0, 0);\nconst resp = httpItems[0]?.json;\nconst insertedArray = Array.isArray(resp) ? resp : (resp?.body ?? []);\nconst inserted = new Set(insertedArray.map(r => r.hash));\n\n// === 3) Control de \"primera vez\" o siguientes ===\nif (!sd.initialized) {\n  // Primera ejecución: deja pasar TODO y marca como inicializado\n  sd.initialized = true;\n  return originals;\n}\n\n// === 4) Ejecuciones siguientes: solo los nuevos ===\nreturn originals.filter(i => inserted.has(i.json.hash));"
      },
