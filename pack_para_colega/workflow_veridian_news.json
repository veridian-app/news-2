    {
      "parameters": {
        "jsCode": "// CÓDIGO PARA EL NODO: Preparar_Cluster\n// Asegúrate de que este nodo también esté en Mode: \"Run Once for All Items\"\n\n// 1. Obtenemos todas las noticias\nconst allNews = items.map(item => item.json);\n\n// 2. Creamos la lista de texto simple para el prompt\nconst simplifiedList = allNews.map((news, index) => {\n  // Limpiamos saltos de línea para que quede limpio\n  const cleanTitle = (news.title || \"\").replace(/\\n/g, \" \");\n  // Creamos el formato \"ID_0: Titulo (Fuente)\"\n  return `ID_${index}: ${cleanTitle} (Fuente: ${news.source})`;\n}).join(\"\\n\");\n\n// 3. Devolvemos la lista lista y los datos originales\nreturn {\n  json: {\n    prompt_list: simplifiedList,\n    original_data: allNews\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2544,
        112
      ],
      "id": "68ef60f7-2054-41b3-933a-e455e2b4835c",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "role": "system",
              "content": "Eres un algoritmo de agrupación de noticias.\nRecibirás una lista de titulares con IDs.\nTu trabajo es agrupar las noticias que traten EXACTAMENTE sobre el mismo evento o tema específico.\n\nReglas:\n1. Devuelve SOLO un JSON válido.\n2. El formato debe ser un objeto con una clave \"grupos\" que contenga arrays de IDs.\n3. NO uses Markdown (nada de ```json).\n\nEjemplo de salida:\n{\n  \"grupos\": [\n    [\"ID_0\", \"ID_5\"],\n    [\"ID_1\"],\n    [\"ID_2\", \"ID_8\"]\n  ]\n}"
            },
            {
              "content": "=Lista de noticias para agrupar:\n{{ $json.prompt_list }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2,
      "position": [
        2752,
        112
      ],
      "id": "e97ae83f-0c91-4a20-9bc4-d24b39e0b2bb",
      "name": "AI_Clusterer",
      "credentials": {
        "openAiApi": {
          "id": "iZxyJx4Mvk5oNqz5",
          "name": "OpenAi account 2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ==========================================\n// 1. EXTRACCIÓN DE DATOS \"A PRUEBA DE BALAS\"\n// ==========================================\nconst item = items[0].json;\n\n// Buscamos la respuesta en todos los sitios posibles\nlet rawData = \n  item.output || \n  item.message?.content || \n  item.response?.text || \n  item.text ||\n  item.content;\n\n// CORRECCIÓN ESPECÍFICA PARA TU ERROR:\n// Si la respuesta es un Objeto con una propiedad \"content\" (como se ve en tu foto)\nif (rawData && typeof rawData === 'object') {\n  if (rawData.content) {\n    rawData = rawData.content;\n  }\n}\n\n// Si resulta que es un Array (lista), cogemos el primer elemento o lo convertimos todo\nif (Array.isArray(rawData)) {\n  // A veces viene como [{ \"text\": \"...\" }] o simplemente [\"...\"]\n  rawData = rawData[0].text || rawData[0] || JSON.stringify(rawData);\n}\n\n// SIEMPRE convertimos a String para evitar el error \".replace is not a function\"\nconst aiString = typeof rawData === 'string' ? rawData : JSON.stringify(rawData);\n\nif (!aiString || aiString === \"{}\" || aiString === \"null\") {\n  return []; // Si no hay datos útiles, salimos suavemente\n}\n\n// ==========================================\n// 2. LIMPIEZA Y PARSEO\n// ==========================================\n// Ahora sí es seguro usar .replace() porque 'aiString' es texto 100% seguro\nconst cleanJson = aiString.replace(/```json|```/g, '').trim();\nlet llmResponse;\n\ntry {\n  llmResponse = JSON.parse(cleanJson);\n} catch (e) {\n  // Si falla el parseo, devolvemos array vacío\n  return [];\n}\n\n// ==========================================\n// 3. RECUPERAR DATOS ORIGINALES (VIAJE EN EL TIEMPO)\n// ==========================================\nlet originalData = [];\ntry {\n  const sourceNode = $('Code in JavaScript1').first();\n  if (sourceNode && sourceNode.json) {\n    originalData = sourceNode.json.original_data;\n  }\n} catch(e) {}\n\nconst outputItems = [];\n\n// ==========================================\n// 4. RECONSTRUCCIÓN DE GRUPOS\n// ==========================================\nif (llmResponse.grupos && Array.isArray(llmResponse.grupos) && originalData && originalData.length > 0) {\n    llmResponse.grupos.forEach(grupoIds => {\n      const noticiasDelGrupo = [];\n\n      grupoIds.forEach(idString => {\n        // Extraemos \"ID_5\" -> 5\n        const parts = String(idString).split('_');\n        if (parts.length > 1) {\n            const index = parseInt(parts[1]); \n            if (originalData[index]) {\n              noticiasDelGrupo.push(originalData[index]);\n            }\n        }\n      });\n\n      if (noticiasDelGrupo.length > 0) {\n        const contexto = noticiasDelGrupo.map(n => {\n          const src = n.source || 'Fuente desconocida';\n          const tit = n.title || 'Sin título';\n          const desc = n.content_for_llm || n.description || '';\n          const lnk = n.link || '';\n          return `--- FUENTE: ${src} ---\\nTITULAR: ${tit}\\nCONTENIDO: ${desc}\\nLINK: ${lnk}`;\n        }).join('\\n\\n');\n\n        const links = noticiasDelGrupo.map(n => n.link).filter(Boolean).join(', ');\n        const fuentes = [...new Set(noticiasDelGrupo.map(n => n.source).filter(Boolean))].join(', ');\n\n        outputItems.push({\n          json: {\n            tema: noticiasDelGrupo[0].title,\n            fuentes_usadas: fuentes,\n            links_referencia: links,\n            contexto_completo: contexto\n          }\n        });\n      }\n    });\n}\n\nreturn outputItems;"
      },
